{
  "name": "mobile-dev-cleaner",
  "version": "1.0.0",
  "description": "TUI to scan and clean Xcode and Android Studio junk on macOS — DerivedData, simulators, AVDs, Gradle caches, SDKs, and more.",
  "type": "module",
  "bin": {
    "mdc": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "xcode",
    "android-studio",
    "cleanup",
    "macos",
    "developer-tools",
    "ios",
    "android",
    "simulator",
    "avd",
    "derived-data",
    "gradle",
    "tui",
    "cli"
  ],
  "homepage": "https://github.com/LeoMogiano/mdc-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeoMogiano/mdc-cli.git"
  },
  "bugs": {
    "url": "https://github.com/LeoMogiano/mdc-cli/issues"
  },
  "author": "LeoMogiano <https://github.com/LeoMogiano>",
  "license": "MIT",
  "os": [
    "darwin"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fast-xml-parser": "^5.7.2",
    "ink": "^7.0.1",
    "p-limit": "^7.3.0",
    "react": "^19.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "eslint": "^9.0.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
